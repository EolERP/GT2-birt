  <Script>
/**
 * Called before rendering Series.
 * 
 * @param series
 *            Series
 * @param isr
 *            ISeriesRenderer
 * @param icsc
 *            IChartScriptContext
 */

function beforeDrawSeries( series, isr, icsc )
{

    importPackage(Packages.org.eclipse.birt.chart.model.data.impl);
    importPackage(Packages.org.eclipse.birt.chart.model.component.impl);
    var v1 = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue1&quot;);
    var v2 = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue2&quot;);
    var v3 = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue3&quot;);
    var v4 = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue4&quot;);
    var v1pl = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue1pl&quot;);
    var v2pl = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue2pl&quot;);
    var v3pl = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue3pl&quot;);
    var v4pl = icsc.getExternalContext().getScriptable().getPersistentGlobalVariable(&quot;varp_chLvalue4pl&quot;);
    
	if( 
		(series.getSeriesIdentifier() == &quot;Series 1&quot; &amp;&amp; (v1 != null &amp;&amp; v1.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 2&quot; &amp;&amp; (v2 != null &amp;&amp; v2.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 3&quot; &amp;&amp; (v3 != null &amp;&amp; v3.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 4&quot; &amp;&amp; (v4 != null &amp;&amp; v4.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 5&quot; &amp;&amp; (v1pl != null &amp;&amp; v1pl.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 6&quot; &amp;&amp; (v2pl != null &amp;&amp; v2pl.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 7&quot; &amp;&amp; (v3pl != null &amp;&amp; v3pl.length() > 0)) || 
		(series.getSeriesIdentifier() == &quot;Series 8&quot; &amp;&amp; (v4pl != null &amp;&amp; v4pl.length() > 0)) 
	){
		series.setVisible(true);
	}else{
		series.setVisible(false);
	}	
	
}

</Script>
