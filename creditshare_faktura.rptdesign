                                </data>
                            </cell>
                        </row>
                    </grid>
                </cell>
            </row>
        </grid>
    </body>
    <property name="pageVariables">
        <variable-element name="countOblasti">
            <expression name="value" type="javascript">0</expression>
            <property name="type">report</property>
        </variable-element>
        <variable-element name="countKriteria">
            <expression name="value" type="javascript">0</expression>
            <property name="type">report</property>
        </variable-element>
        <variable-element name="countSignaly">
            <expression name="value" type="javascript">0</expression>
            <property name="type">report</property>
        </variable-element>
    </property>
</report>
